# Backend Environment Configuration Example
# Required Variables

# Purpose: Secret key used to sign and verify JSON Web Tokens (JWT) for authentication. Must be at least 32 characters.
# Required: Yes
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_chars_long_for_dev

# Zoho Catalyst QuickML OAuth
CATALYST_PROJECT_ID=49792000000013051
CATALYST_ORG_ID=60078654574
CATALYST_CLIENT_ID=1000.your_client_id
CATALYST_CLIENT_SECRET=your_client_secret
CATALYST_REDIRECT_URL=https://your-backend.example.com/api/v1/ai/oauth/callback
CATALYST_ENVIRONMENT=production
CATALYST_MODEL_ID=Qwen 2.5 - 14B Instruct
CATALYST_QUICKML_ENDPOINT_URL=https://copy-this-from-quickml-api-details
CATALYST_QUICKML_ENDPOINT_KEY=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_REFRESH_TOKEN=
CATALYST_OAUTH_SETUP_SECRET=generate_a_long_random_setup_secret
